{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_API_URL": "@pantheon_api_url",
    "NEXT_PUBLIC_WS_URL": "@pantheon_ws_url",
    "NEXT_PUBLIC_SUPABASE_URL": "@pantheon_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@pantheon_supabase_anon_key",
    "NEXT_PUBLIC_APP_URL": "@pantheon_app_url"
  }
}
